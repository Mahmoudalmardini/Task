# ────────── Application ──────────
NODE_ENV=development
PORT=3000

# ────────── MongoDB ──────────
MONGO_URI=mongodb://localhost:27017/delivery_ops

# ────────── JWT ──────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ────────── Admin seed ──────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123

# ────────── Partner API ──────────
# The raw key is printed to stdout during seeding.
# It is stored hashed (bcrypt) in the api_keys collection.
PARTNER_RATE_LIMIT_TTL_SECONDS=60
PARTNER_RATE_LIMIT_MAX=60

# ────────── Idempotency ──────────
IDEMPOTENCY_TTL_HOURS=24
